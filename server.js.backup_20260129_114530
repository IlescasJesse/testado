      if (!text || text.trim() === "") {
        return; // Línea vacía
      }

      const words = text.trim().split(/\s+/);

      // Si es una sola palabra o línea corta, alinear a la izquierda
      if (words.length === 1) {
        newPage2.drawText(text, {
          x: x,
          y: y,
          size: size,
          font: font,
          color: rgb(0, 0, 0),
        });
        return;
      }

      // Calcular ancho total de todas las palabras
      let totalWordWidth = 0;
      words.forEach((word) => {
        totalWordWidth += font.widthOfTextAtSize(word, size);
      });

      // Calcular espacio disponible para distribuir entre palabras
      const totalSpaceWidth = maxWidth - totalWordWidth;
      const spaceWidth = totalSpaceWidth / (words.length - 1);

      // Dibujar cada palabra con el espacio calculado
      let currentX = x;
      words.forEach((word, index) => {
        newPage2.drawText(word, {
          x: currentX,
          y: y,
          size: size,
          font: font,
          color: rgb(0, 0, 0),
        });

        const wordWidth = font.widthOfTextAtSize(word, size);
        currentX += wordWidth + spaceWidth;
      });
    }

    // Dibujar cada línea (justificar solo las largas)
    leyendaTexto.forEach((linea, index) => {
      const yPos =
        leyendaY + leyendaHeight - (margin + index * lineHeight) - fontSize;

