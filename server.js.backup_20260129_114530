/**
 * Encripta el PDF usando qpdf para proteger contra edición.
 * Requiere qpdf instalado (Windows: choco install qpdf)
 */
async function encryptPdfWithQpdf(filePath, ownerPassword) {
  return new Promise((resolve, reject) => {
    const tmpPath = `${filePath}.enc`;

    const args = [
      "--encrypt",
      "", // user password vacío (abre sin contraseña)
      ownerPassword, // owner password (protege edición)
      "256", // encriptación AES-256
      "--modify=none", // prohibir modificación
      "--print=full", // permitir impresión
      "--",
      filePath,
      tmpPath,
    ];

    const res = spawnSync("qpdf", args, { stdio: "pipe" });

    if (res.error) {
      return reject(res.error);
    }
    if (res.status !== 0) {
      return reject(new Error(`qpdf finalizó con código ${res.status}`));
    }

    // Reemplazar archivo original por el encriptado
    fs.renameSync(tmpPath, filePath);
    resolve();
  });
}

// Crear servidor HTTP
const PORT = 3001;
const server = http.createServer((req, res) => {
  // CORS headers para todas las respuestas
  res.setHeader("Access-Control-Allow-Origin", "*");
  res.setHeader(
    "Access-Control-Allow-Methods",
    "GET, POST, OPTIONS, PUT, DELETE"
  );
  res.setHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");
  res.setHeader("Access-Control-Max-Age", "86400");

  if (req.method === "OPTIONS") {
    res.writeHead(200);
    res.end();
    return;
  }

  // Log de solicitudes para debugging
  console.log(`${new Date().toISOString()} - ${req.method} ${req.url}`);

  // API Routes
  if (req.url === "/api/pdfs" && req.method === "GET") {
    try {
      const contractsDir = path.join(__dirname, "contratos");
      if (!fs.existsSync(contractsDir)) {
        fs.mkdirSync(contractsDir, { recursive: true });
      }
      const files = fs
        .readdirSync(contractsDir)
        .filter((file) => file.toLowerCase().endsWith(".pdf"));

      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(JSON.stringify(files));
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  if (req.url.startsWith("/api/pdf/") && req.method === "GET") {
    const filename = decodeURIComponent(req.url.replace("/api/pdf/", ""));
    const filepath = path.join(__dirname, "contratos", filename);

    try {
      if (fs.existsSync(filepath)) {
        const pdf = fs.readFileSync(filepath);
        res.writeHead(200, { "Content-Type": "application/pdf" });
        res.end(pdf);
      } else {
        res.writeHead(404, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ error: "PDF not found" }));
      }
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  if (req.url === "/api/process" && req.method === "POST") {
    const bb = Busboy({ headers: req.headers });
    const uploadDir = path.join(__dirname, "temp_uploads");
    const outputDir = path.join(__dirname, "tested_Censurado");

    if (!fs.existsSync(uploadDir)) {
      fs.mkdirSync(uploadDir, { recursive: true });
    }
    if (!fs.existsSync(outputDir)) {
      fs.mkdirSync(outputDir, { recursive: true });
    }

    const uploadedFiles = [];
    const processLogs = [];
    const filePromises = [];

    // Manejar archivos
    bb.on("file", (fieldname, file, info) => {
      const filename = info.filename;
      const filepath = path.join(uploadDir, filename);
      const outputPath = path.join(outputDir, filename);

      const writeStream = fs.createWriteStream(filepath);
      file.pipe(writeStream);

      // Crear promesa para procesar después
      const filePromise = new Promise((resolve) => {
        writeStream.on("finish", () => {
          uploadedFiles.push({ filename, filepath, outputPath });
          resolve();
        });
        writeStream.on("error", (error) => {
          console.error(`❌ Error guardando ${filename}: ${error.message}`);
          resolve();
        });
      });

      filePromises.push(filePromise);
    });

    bb.on("close", async () => {
      // Esperar a que se guarden todos los archivos
      await Promise.all(filePromises);

      console.log(
        `\n📄 Recibidos ${uploadedFiles.length} archivos para procesar\n`
      );

      // RESPONDER INMEDIATAMENTE
      res.writeHead(202, { "Content-Type": "application/json" });
      res.end(
        JSON.stringify({
          success: true,
          message: `Procesando ${uploadedFiles.length} archivos en segundo plano`,
          total: uploadedFiles.length,
          status: "processing",
        })
      );

      // PROCESAR EN SEGUNDO PLANO (no bloquea la respuesta)
      (async () => {
        for (let i = 0; i < uploadedFiles.length; i++) {
          const { filename, filepath, outputPath } = uploadedFiles[i];
          try {
            console.log(`[${i + 1}/${uploadedFiles.length}] ${filename}`);
            await censorPdf(filepath, outputPath, {});
            if (fs.existsSync(filepath)) fs.unlinkSync(filepath);
            processLogs.push({ file: filename, success: true });
            console.log(`✅ Completado\n`);
          } catch (error) {
            console.error(`❌ ${filename}: ${error.message}`);
            processLogs.push({
              file: filename,
              success: false,
              error: error.message,
            });
          }
        }

        // Guardar log de errores en TXT
        const errorLogs = processLogs.filter((log) => !log.success);
        if (errorLogs.length > 0) {
          const timestamp = new Date().toLocaleString("es-MX");
          let logContent = `=================================================\n`;
          logContent += `LOG DE ERRORES - ${timestamp}\n`;
          logContent += `=================================================\n\n`;
          logContent += `Total procesados: ${uploadedFiles.length}\n`;
          logContent += `Exitosos: ${
            processLogs.filter((l) => l.success).length
          }\n`;
          logContent += `Fallidos: ${errorLogs.length}\n\n`;
          logContent += `ARCHIVOS CON ERROR:\n`;
          logContent += `-------------------------------------------------\n\n`;

          errorLogs.forEach((log, index) => {
            logContent += `${index + 1}. ${log.file}\n`;
            logContent += `   Error: ${log.error}\n\n`;
          });

          const logPath = path.join(outputDir, "errores_procesamiento.txt");
          fs.writeFileSync(logPath, logContent, "utf8");
          console.log(
            `\n📝 Log de errores guardado: errores_procesamiento.txt`
          );
        }

        console.log(
          `\n✅ Procesamiento completo: ${
            processLogs.filter((l) => l.success).length
          }/${uploadedFiles.length} exitosos\n`
        );
      })();
    });

    bb.on("error", (error) => {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    });

    req.pipe(bb);
    return;
  }

  // Listar archivos testados
  if (req.url === "/api/tested-files" && req.method === "GET") {
    try {
      const testedDir = path.join(__dirname, "tested_Censurado");
      if (!fs.existsSync(testedDir)) {
        fs.mkdirSync(testedDir, { recursive: true });
      }
      const files = fs
        .readdirSync(testedDir)
        .filter((f) => f.toLowerCase().endsWith(".pdf"))
        .map((f) => {
          const stats = fs.statSync(path.join(testedDir, f));
          return {
            name: f,
            size: stats.size,
            date: stats.mtime,
          };
        })
        .sort((a, b) => b.date - a.date);

      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ success: true, files }));
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  // Descargar archivo testado individual
  if (req.url.startsWith("/api/download-tested/") && req.method === "GET") {
    try {
      const fileName = decodeURIComponent(
        req.url.split("/api/download-tested/")[1]
      );
      const filePath = path.join(__dirname, "tested_Censurado", fileName);

      if (!fs.existsSync(filePath)) {
        res.writeHead(404, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ error: "Archivo no encontrado" }));
        return;
      }

      const fileData = fs.readFileSync(filePath);
      res.writeHead(200, {
        "Content-Type": "application/pdf",
        "Content-Disposition": `attachment; filename="${fileName}"`,
        "Content-Length": fileData.length,
      });
      res.end(fileData);
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  // Descargar todos los testados en ZIP
  if (req.url === "/api/download-all-tested" && req.method === "GET") {
    try {
      const archiver = require("archiver");
      const testedDir = path.join(__dirname, "tested_Censurado");

      if (!fs.existsSync(testedDir)) {
        res.writeHead(404, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ error: "No hay archivos testados" }));
        return;
      }

      const files = fs
        .readdirSync(testedDir)
        .filter((f) => f.toLowerCase().endsWith(".pdf"));

      if (files.length === 0) {
        res.writeHead(404, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ error: "No hay archivos para descargar" }));
        return;
      }

      const timestamp = new Date()
        .toISOString()
        .replace(/[:.]/g, "-")
        .slice(0, -5);
      const zipName = `Testados_${timestamp}.zip`;

      res.writeHead(200, {
        "Content-Type": "application/zip",
        "Content-Disposition": `attachment; filename="${zipName}"`,
      });

      const archive = archiver("zip", { zlib: { level: 9 } });
      archive.pipe(res);

      // Agregar archivos PDF
      files.forEach((file) => {
        const filePath = path.join(testedDir, file);
        archive.file(filePath, { name: file });
      });

      // Agregar log de errores si existe
      const errorLogPath = path.join(testedDir, "errores_procesamiento.txt");
      if (fs.existsSync(errorLogPath)) {
        archive.file(errorLogPath, { name: "errores_procesamiento.txt" });
      }

      archive.finalize();
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  // Eliminar todos los archivos testados
  if (req.url === "/api/clear-tested" && req.method === "POST") {
    try {
      const testedDir = path.join(__dirname, "tested_Censurado");

      if (!fs.existsSync(testedDir)) {
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(
          JSON.stringify({
            success: true,
            message: "No hay archivos para eliminar",
          })
        );
        return;
      }

      const files = fs
        .readdirSync(testedDir)
        .filter((f) => f.toLowerCase().endsWith(".pdf"));

      files.forEach((file) => {
        const filePath = path.join(testedDir, file);
        fs.unlinkSync(filePath);
      });

      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(
        JSON.stringify({
          success: true,
          message: `${files.length} archivo${
            files.length !== 1 ? "s" : ""
          } eliminado${files.length !== 1 ? "s" : ""}`,
        })
      );
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  if (req.url === "/api/open-folder" && req.method === "GET") {
    try {
      const { exec } = require("child_process");
      const testedDir = path.join(__dirname, "tested_Censurado");
      if (!fs.existsSync(testedDir)) {
        fs.mkdirSync(testedDir, { recursive: true });
      }
      exec(`explorer "${testedDir}"`);
      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ success: true }));
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  // Guardar configuración de contrato
  if (req.url === "/api/config/save" && req.method === "POST") {
    let body = "";
    req.on("data", (chunk) => {
      body += chunk.toString();
    });
    req.on("end", () => {
      try {
        const { contractName, config } = JSON.parse(body);
        const configDir = path.join(__dirname, "config");
        if (!fs.existsSync(configDir))
          fs.mkdirSync(configDir, { recursive: true });
        const configFile = path.join(configDir, `${contractName}.json`);
        fs.writeFileSync(configFile, JSON.stringify(config, null, 2));
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ success: true }));
      } catch (error) {
        res.writeHead(500, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ error: error.message }));
      }
    });
    return;
  }

  // Cargar configuración de contrato
  if (req.url.startsWith("/api/config/load") && req.method === "GET") {
    try {
      const urlObj = new URL(req.url, `http://localhost:${PORT}`);
      const name = urlObj.searchParams.get("name");
      const configFile = path.join(__dirname, "config", `${name}.json`);
      if (fs.existsSync(configFile)) {
        const data = fs.readFileSync(configFile, "utf8");
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(data);
      } else {
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(JSON.stringify(null));
      }
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  // Guardar preset activo (usar preset para todos los PDFs)
  if (req.url === "/api/config/set-active" && req.method === "POST") {
    let body = "";
    req.on("data", (chunk) => {
      body += chunk.toString();
    });
    req.on("end", () => {
      try {
        const { presetName } = JSON.parse(body);
        const configDir = path.join(__dirname, "config");
        if (!fs.existsSync(configDir))
          fs.mkdirSync(configDir, { recursive: true });
        const activeFile = path.join(configDir, "active_preset.json");
        fs.writeFileSync(activeFile, JSON.stringify({ presetName }, null, 2));
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ success: true }));
      } catch (error) {
        res.writeHead(500, { "Content-Type": "application/json" });
        res.end(JSON.stringify({ error: error.message }));
      }
    });
    return;
  }

  // Obtener preset activo
  if (req.url === "/api/config/active" && req.method === "GET") {
    try {
      const activeFile = path.join(__dirname, "config", "active_preset.json");
      if (fs.existsSync(activeFile)) {
        const data = fs.readFileSync(activeFile, "utf8");
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(data);
      } else {
        res.writeHead(200, { "Content-Type": "application/json" });
        res.end(JSON.stringify(null));
      }
    } catch (error) {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: error.message }));
    }
    return;
  }

  // Servir archivos estáticos
  let filepath = path.join(__dirname, req.url === "/" ? "index.html" : req.url);

  // Prevenir path traversal
  const normalizedPath = path.normalize(filepath);
  if (!normalizedPath.startsWith(__dirname)) {
    res.writeHead(403, { "Content-Type": "text/html" });
    res.end("<h1>403 - Acceso denegado</h1>");
    return;
  }

  fs.readFile(filepath, (err, data) => {
    if (err) {
      res.writeHead(404, { "Content-Type": "text/html" });
      res.end("<h1>404 - Archivo no encontrado</h1>");
      return;
    }

    const ext = path.extname(filepath);
    const mimeTypes = {
      ".html": "text/html",
      ".css": "text/css",
      ".js": "text/javascript",
      ".json": "application/json",
      ".png": "image/png",
      ".jpg": "image/jpeg",
      ".gif": "image/gif",
      ".svg": "image/svg+xml",
      ".ico": "image/x-icon",
    };

    const contentType = mimeTypes[ext] || "text/plain";
    res.writeHead(200, {
      "Content-Type": contentType,
      "Cache-Control": "no-cache",
    });
    res.end(data);
  });
});

server.listen(PORT, "0.0.0.0", () => {
  const os = require("os");
  const networkInterfaces = os.networkInterfaces();
  let localIP = "localhost";

  // Obtener IP local de la red
  for (const name of Object.keys(networkInterfaces)) {
    for (const net of networkInterfaces[name]) {
      // Ignorar direcciones IPv6 y loopback
      if (net.family === "IPv4" && !net.internal) {
        localIP = net.address;
        break;
      }
    }
    if (localIP !== "localhost") break;
  }

  console.log(`✅ Servidor iniciado en puerto ${PORT}`);
  console.log(`\n📍 ACCESOS DISPONIBLES:`);
  console.log(`   Local:    http://localhost:${PORT}`);
  console.log(`   Red:      http://${localIP}:${PORT}`);
  console.log(
    `\n🌐 Otras PCs pueden acceder usando: http://${localIP}:${PORT}`
  );
  console.log(`⏹️  Presiona Ctrl+C para detener el servidor\n`);

  // Abrir navegador automáticamente (Windows)
  try {
    const { exec } = require("child_process");
    exec(`start http://localhost:${PORT}`);
  } catch (e) {
    // Silencioso
  }
});

process.on("SIGINT", () => {
  process.exit(0);
});
