// Función para detectar RFC - Solo usa OCR (sin coordenadas fijas)
async function detectarRFCEnTexto(pdfBytes, pageIndex = 1) {
  try {
    // Detectar y testar RFC directamente en la imagen
    const resultado = await detectarYTestarRFCEnImagen(pdfBytes, pageIndex);

