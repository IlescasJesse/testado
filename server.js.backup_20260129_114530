// Función para extraer RFC usando OCR y TESTAR directamente en la imagen
async function detectarYTestarRFCEnImagen(pdfBytes, pageIndex = 1) {
  let tempPdfPath = null;
  let imgPath = null;

  try {
    // Guardar PDF temporalmente
    tempPdfPath = path.join(
      __dirname,
      "temp_uploads",
      `temp_${Date.now()}.pdf`
    );
    fs.writeFileSync(tempPdfPath, pdfBytes);

    // Configuración para poppler
    const opts = {
      format: "png",
      out_dir: path.join(__dirname, "temp_uploads"),
      out_prefix: `ocr_${Date.now()}`,
      page: pageIndex + 1, // página 2
      scale: 2048, // Alta resolución
    };

    // Convertir página 2 a imagen PNG
    await poppler.convert(tempPdfPath, opts);

    // Buscar archivo generado
    const outputName = `${opts.out_prefix}-${opts.page}.png`;
    imgPath = path.join(opts.out_dir, outputName);

    if (fs.existsSync(imgPath)) {
      // Aplicar OCR con Tesseract (optimizado)
      const config = {
        lang: "spa",
        oem: 1,
        psm: 3, // Más rápido
      };

      // Obtener texto completo
      const text = await tesseract.recognize(imgPath, config);

      // Ejecutar tesseract directamente para obtener TSV
      const { execSync } = require("child_process");
      const tsvPath = imgPath.replace(".png", ".tsv");
      execSync(
        `tesseract "${imgPath}" "${tsvPath.replace(
          ".tsv",
          ""
        )}" -l spa --oem 1 --psm 3 tsv`,
        { encoding: "utf8" }
      );
      const tsv = fs.readFileSync(tsvPath, "utf8");

      // Buscar RFC en texto OCR
      const regex = /n[uú]mero\s*:?\s*([A-ZÑ&]{4}\d{6}[A-Z0-9]{3})/i;
      const match = text.match(regex);

      if (match && match[1]) {
        const rfc = match[1].replace(/[^A-Z0-9Ñ&]/g, "").toUpperCase();
        if (rfc.length === 13) {
          console.log(`   ✓ RFC: ${rfc}`);

          // Cargar imagen para testar
          const image = await loadImage(imgPath);
          const canvas = createCanvas(image.width, image.height);
          const ctx = canvas.getContext("2d");
          ctx.drawImage(image, 0, 0);

          const lines = tsv.split("\n");
          let rfcFound = false;
          let minX = Infinity,
            minY = Infinity,
            maxX = 0,
            maxY = 0;

          // Buscar el RFC completo primero
          let foundParts = [];
          for (let i = 1; i < lines.length; i++) {
            const cols = lines[i].split("\t");
            if (cols.length < 12) continue;

            const rawText = cols[11]?.trim() || "";
            const text = rawText.toUpperCase().replace(/[^A-Z0-9]/g, "");
            const left = parseInt(cols[6]);
            const top = parseInt(cols[7]);
            const w = parseInt(cols[8]);
            const h = parseInt(cols[9]);

            if (!text || isNaN(left) || isNaN(top)) continue;

            // Buscar el RFC exacto completo primero
            if (text === rfc) {
              minX = left;
              minY = top;
              maxX = left + w;
              maxY = top + h;
              rfcFound = true;
              foundParts.push(rawText);
              break; // RFC completo encontrado, salir
            }
          }

          // Si no encontró el RFC completo, buscar fragmentos grandes
          if (!rfcFound) {
            for (let i = 1; i < lines.length; i++) {
              const cols = lines[i].split("\t");
              if (cols.length < 12) continue;

              const rawText = cols[11]?.trim() || "";
              const text = rawText.toUpperCase().replace(/[^A-Z0-9]/g, "");
              const left = parseInt(cols[6]);
              const top = parseInt(cols[7]);
              const w = parseInt(cols[8]);
              const h = parseInt(cols[9]);

              if (!text || isNaN(left) || isNaN(top)) continue;

              // Buscar fragmentos de 8+ caracteres (más restrictivo para evitar matches en dirección)
              if (text.length >= 8 && rfc.includes(text)) {
                minX = Math.min(minX, left);
                minY = Math.min(minY, top);
                maxX = Math.max(maxX, left + w);
                maxY = Math.max(maxY, top + h);
                rfcFound = true;
                foundParts.push(rawText);
              }
            }
          }

          // Cargar fuente Montserrat
          const { registerFont } = require("canvas");
          registerFont(
            path.join(__dirname, "fonts", "Montserrat-Regular.ttf"),
            { family: "Montserrat" }
          );

          let x, y, width, height;

          // Si encontramos coordenadas, usar las reales
          if (rfcFound && minX < Infinity) {
            x = minX;
            y = minY;
            width = maxX - minX;
            height = maxY - minY;
          } else {
            // Fallback OBLIGATORIO: buscar "b)" y "número" o usar posición por defecto
            let fallbackY = 690;
            let fallbackX = 970;
            let foundB = false;

            // Buscar "b)" seguido de "número"
            for (let i = 1; i < lines.length; i++) {
              const cols = lines[i].split("\t");
              if (cols.length < 12) continue;
              const text = cols[11]?.trim().toLowerCase() || "";

              if (text.includes("b)")) {
                foundB = true;
                for (let j = i; j < Math.min(i + 20, lines.length); j++) {
                  const cols2 = lines[j].split("\t");
                  if (cols2.length < 12) continue;
                  const text2 = cols2[11]?.trim().toLowerCase() || "";

                  if (text2.includes("número") && !text2.includes("edificio")) {
                    fallbackY = parseInt(cols2[7]) || fallbackY;
                    fallbackX =
                      parseInt(cols2[6]) + parseInt(cols2[8]) + 50 || fallbackX;
                    break;
                  }
                }
                if (foundB) break;
              }
            }

            // Usar fallback (coordenadas aproximadas o detectadas)
            x = fallbackX - 10;
            y = fallbackY - 8;
            width = 240;
            height = 38;
          }

          // SIEMPRE dibujar rectángulo negro
          ctx.fillStyle = "#000000";
          ctx.fillRect(
            x,
            y,
            width + (rfcFound ? 25 : 0),
            height + (rfcFound ? 16 : 0)
          );

          // Texto "1. RFC" centrado
          ctx.fillStyle = "#FFFFFF";
          ctx.font = "bold 38px Montserrat";
          ctx.textAlign = "center";
          ctx.fillText("1. RFC", x + width / 2, y + height / 2 + 18);

          // Guardar imagen testada
          const testedImgPath = path.join(
            opts.out_dir,
            `tested_${Date.now()}.png`
          );
          const buffer = canvas.toBuffer("image/png");
          fs.writeFileSync(testedImgPath, buffer);

          // Limpiar imagen original
          fs.unlinkSync(imgPath);

          return {
            rfc: rfc,
            testedImagePath: testedImgPath,
          };
        }
      }
    }

    return null;
  } catch (error) {
    console.log(`⚠ OCR: ${error.message}`);
    return null;
  } finally {
    // Limpiar PDF temporal
    if (tempPdfPath && fs.existsSync(tempPdfPath)) fs.unlinkSync(tempPdfPath);
  }
}

// Buscar coordenadas del RFC en la imagen (en píxeles)
function findRFCCoordinatesEnImagen(tsvData, rfc) {
  try {
    const lines = tsvData.split("\n");
    const rfcChars = rfc.split("");
    const foundPositions = [];

    for (let i = 1; i < lines.length; i++) {
      const cols = lines[i].split("\t");
      if (cols.length < 12) continue;

      const text = cols[11]?.trim().toUpperCase();
      const left = parseInt(cols[6]);
      const top = parseInt(cols[7]);
      const width = parseInt(cols[8]);
      const height = parseInt(cols[9]);

      if (!isNaN(left) && !isNaN(top) && text) {
        for (const char of rfcChars) {
          if (text.includes(char)) {
            foundPositions.push({ left, top, width, height });
            break;
          }
        }
      }
    }

    if (foundPositions.length > 0) {
      const minLeft = Math.min(...foundPositions.map((p) => p.left));
      const minTop = Math.min(...foundPositions.map((p) => p.top));
      const maxRight = Math.max(...foundPositions.map((p) => p.left + p.width));
      const maxBottom = Math.max(
        ...foundPositions.map((p) => p.top + p.height)
      );

      return {
        x: minLeft,
        y: minTop,
        width: maxRight - minLeft,
        height: maxBottom - minTop,
      };
    }

    return null;
  } catch (error) {
    return null;
  }
}

