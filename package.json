{
  "name": "testado",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Aplicación para testear y censurar PDFs de contratos",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg server.js --targets win --output testado.exe"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "archiver": "^7.0.1",
    "busboy": "^1.6.0",
    "canvas": "^3.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "multer": "^2.0.2",
    "node-tesseract-ocr": "^2.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf-poppler": "^0.2.3",
    "pdfjs-dist": "^3.11.174",
    "sharp": "^0.33.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "build": {
    "appId": "com.testado.app",
    "productName": "Testado - Gestor de Contratos",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "index.js",
      "node_modules/**/*",
      "contratos/**/*",
      "tested_Censurado/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
